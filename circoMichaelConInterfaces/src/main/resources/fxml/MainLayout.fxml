<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../styles/Styles.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.luisdbb.tarea3AD2024base.controller.MainLayoutController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="20" styleClass="header-bar">
            <Label fx:id="lblBienvenida" styleClass="header-title" text="👋 Bienvenido" />
        </HBox>
    </top>
    <left>
        <VBox fx:id="menuLateral" prefWidth="211" spacing="15" styleClass="menu-box">
            <Button fx:id="btnPersonas"
                    onAction="#goPersonas"
                    prefHeight="47" prefWidth="155"
                    styleClass="menu-button"
                    text="👥 Personas"/>
            <Button fx:id="btnEspectaculos"
                    onAction="#goEspectaculos"
                    prefHeight="47" prefWidth="155"
                    styleClass="menu-button"
                    text="🎪 Espectáculos"/>
            <Button fx:id="btnVerEspectaculos"
                    onAction="#goVerEspectaculos"
                    prefHeight="47" prefWidth="155"
                    styleClass="menu-button"
                    text="👁 Espectáculos"
                    visible="false" managed="false"/>

            <Button fx:id="btnFichaArtista"
                    onAction="#goFichaArtista"
                    prefHeight="47" prefWidth="155"
                    styleClass="menu-button"
                    text="🎭 Mi Ficha"
                    visible="false" managed="false"/>
            <Button fx:id="btnLogs"
			        text="📜 Ver Logs"
			        styleClass="menu-button"
			        onAction="#goLogs" />
            <Button onAction="#logout"
                    prefHeight="39" prefWidth="155"
                    styleClass="cancel-button"
                    text="🚪 Cerrar Sesión" />

        </VBox>
    </left>
    <center>
        <StackPane fx:id="contenedorPantallas" styleClass="content-wrapper" />
    </center>

</BorderPane>
