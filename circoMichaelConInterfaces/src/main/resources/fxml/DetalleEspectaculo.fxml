<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="15" styleClass="detail-box" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.DetalleEspectaculoController">

    <Label fx:id="lblTitulo" styleClass="detail-title" text="🎪 Detalle del Espectáculo" />
    <Label styleClass="detail-label" text="📅 Fecha de inicio" />
    <Label fx:id="lblInicio" styleClass="detail-value" />
    <Label styleClass="detail-label" text="📅 Fecha de fin" />
    <Label fx:id="lblFin" styleClass="detail-value" />
    <Label styleClass="detail-label" text="👤 Coordinador" />
    <Label fx:id="lblCoordinador" styleClass="detail-value" />
    <Label styleClass="detail-label" text="🎫 Números del espectáculo" />
    <TableView fx:id="tablaNumeros" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colOrden" prefWidth="80" text="Orden" />
            <TableColumn fx:id="colNombre" prefWidth="232.0" text="Nombre" />
            <TableColumn fx:id="colDuracion" prefWidth="118.0" text="Duración (min)" />
            <TableColumn fx:id="colArtistas" prefWidth="419.0" text="Artistas" />
        </columns>
    </TableView>
    <Button onAction="#onVolver" styleClass="cancel-button" text="↩️ Volver" />

</VBox>
