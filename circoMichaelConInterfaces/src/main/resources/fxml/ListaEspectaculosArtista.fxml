<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" spacing="15" styleClass="panel-box" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.ListaEspectaculosArtistaController">

    <Label styleClass="panel-title" text="🎪 Espectáculos del Circo" />
    <TableView fx:id="tablaEspectaculos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="80" text="ID" />
            <TableColumn fx:id="colNombre" prefWidth="200" text="Nombre" />
            <TableColumn fx:id="colInicio" prefWidth="150" text="Fecha Inicio" />
            <TableColumn fx:id="colFin" prefWidth="150" text="Fecha Fin" />
        </columns>
    </TableView>
    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="btnDetalle" onAction="#onDetalle" styleClass="action-button" text="👁 Ver Detalle" />
    </HBox>

</VBox>
