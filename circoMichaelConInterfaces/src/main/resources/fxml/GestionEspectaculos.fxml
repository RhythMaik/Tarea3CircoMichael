<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="panel-box" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.GestionEspectaculosController">

    <Label styleClass="panel-title" text="🎪 Gestión de Espectáculos" />
    <HBox alignment="CENTER_LEFT" spacing="10">
        <TextField fx:id="txtBuscar" onKeyReleased="#onBuscar" prefHeight="39.0" prefWidth="560.0" promptText="🔍 Buscar por nombre..." />
        <DatePicker fx:id="dpFechaFiltro" onAction="#onFiltrarFecha" promptText="📅 Filtrar por fecha" />
        <Button onAction="#onLimpiarFiltros" text="Limpiar" />
    </HBox>
    <TableView fx:id="tablaEspectaculos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" minWidth="9.0" prefWidth="66.00005090236664" text="ID" />
            <TableColumn fx:id="colNombre" prefWidth="358.0" text="Nombre" />
            <TableColumn fx:id="colInicio" prefWidth="179.33340454101562" text="Fecha inicio" />
            <TableColumn fx:id="colFin" prefWidth="172.6666259765625" text="Fecha fin" />
            <TableColumn fx:id="colValidacion" prefWidth="72.0" text="Validación" />
        </columns>
    </TableView>
    <HBox spacing="5.0">
        <Button onAction="#onCrear" prefHeight="37.0" prefWidth="70.0" styleClass="action-button" text="Crear" />
        <Button onAction="#onEditar" styleClass="action-button" text="Editar" />
        <Button onAction="#onEliminar" styleClass="action-button" text="Eliminar" />
        <Button onAction="#onVerDetalle" styleClass="action-button" text="Ver detalle" />
        <Button onAction="#onGestionarNumeros" styleClass="action-button" text="Gestionar numeros" />
        <Button onAction="#onExportarJSON" styleClass="action-button" text="Exportar(JSON)" />
        <Button onAction="#onAyuda" styleClass="action-button" text="Ayuda" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#onVolver" styleClass="cancel-button" text="↩ Volver" />
    </HBox>

</VBox>
