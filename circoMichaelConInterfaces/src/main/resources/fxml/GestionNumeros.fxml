<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="panel-box" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.GestionNumerosController">

    <Label fx:id="lblTitulo" styleClass="panel-title" text="🎬 Números del Espectáculo" />
    <TableView fx:id="tablaNumeros" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colOrden" prefWidth="80" text="Orden" />
            <TableColumn fx:id="colNombre" prefWidth="200" text="Nombre" />
            <TableColumn fx:id="colDuracion" prefWidth="120" text="Duración (min)" />
            <TableColumn fx:id="colArtistas" prefWidth="370.6667785644531" text="Artistas" />
            <TableColumn fx:id="colValidacion" prefWidth="73.9998779296875" text="Validación" />
        </columns>
    </TableView>
    <HBox spacing="10">
        <Button onAction="#onCrear" styleClass="action-button" text="Crear numero" />
        <Button onAction="#onEditar" styleClass="action-button" text="Editar numero" />
        <Button onAction="#onEliminar" styleClass="action-button" text="Eliminar numero" />
        <Button onAction="#onGestionarArtistas" styleClass="action-button" text="Gestion artista" />
        <Button onAction="#onAyuda" styleClass="action-button" text="Ayuda" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#onVolver" styleClass="cancel-button" text="↩ Volver" />
    </HBox>

</VBox>
