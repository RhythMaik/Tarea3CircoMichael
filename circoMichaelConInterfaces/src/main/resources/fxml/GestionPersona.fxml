<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="form-box" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.GestionPersonaController">

    <Label fx:id="lblTitulo" styleClass="form-title" text="👤 Nueva Persona" />
    <Label styleClass="form-label" text="🏷 Nombre" />
    <TextField fx:id="txtNombre" styleClass="form-field" />
    <Label styleClass="form-label" text="📧 Email" />
    <TextField fx:id="txtEmail" styleClass="form-field" />
    <Label styleClass="form-label" text="🛡 Perfil" />
    <ComboBox fx:id="cbPerfil" styleClass="form-field" />
    <Button fx:id="btnGuardar" onAction="#onGuardar" styleClass="action-button" text="💾 Guardar" />
    <Button fx:id="btnCancelar" onAction="#onCancelar" styleClass="cancel-button" text="↩ Cancelar" />

</VBox>
