<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" styleClass="detail-box" stylesheets="@../styles/Styles.css" 
      xmlns="http://javafx.com/javafx/25" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.luisdbb.tarea3AD2024base.controller.DetallePersonaController">

    <Label fx:id="lblTitulo" styleClass="detail-title" text="👤 Detalle de la Persona" />
    <Label styleClass="detail-label" text="👤 Nombre" />
    <Label fx:id="lblNombre" styleClass="detail-value" />
    <Label styleClass="detail-label" text="📧 Email" />
    <Label fx:id="lblEmail" styleClass="detail-value" />
    <Label styleClass="detail-label" text="🏷️ Perfil" />
    <Label fx:id="lblPerfil" styleClass="detail-value" />
    <VBox fx:id="panelCoordinacion" alignment="CENTER" managed="false" spacing="10" visible="false">
        <Label styleClass="detail-label" text="🎪 Es senior" />
        <Label fx:id="lblSenior" styleClass="detail-value" />
        <Label styleClass="detail-label" text="📅 Fecha desde" />
        <Label fx:id="lblFechaSenior" styleClass="detail-value" />
    </VBox>
    <VBox fx:id="panelArtista" alignment="CENTER" managed="false" spacing="10" visible="false">
        <Label styleClass="detail-label" text="🎭 Apodo" />
        <Label fx:id="lblApodo" styleClass="detail-value" />
        <Label styleClass="detail-label" text="✨ Especialidades" />
        <Label fx:id="lblEspecialidades" styleClass="detail-value" wrapText="true" />
    </VBox>
    <Button fx:id="btnVolver" onAction="#onVolver" styleClass="cancel-button" text="↩️ Volver" />

</VBox>
