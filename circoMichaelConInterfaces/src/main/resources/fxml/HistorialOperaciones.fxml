<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="15" styleClass="detail-box" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.DetalleEspectaculoController">

    <Label fx:id="lblTitulo" styleClass="detail-title" text="🎪 Historial de operaciones" />
    <TableView fx:id="tablaNumeros" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colOrden" prefWidth="80" text="ID" />
            <TableColumn fx:id="colArtistas" prefWidth="116.66668701171875" text="Usuario" />
         <TableColumn prefWidth="134.66671752929688" text="Tipo de operacion" />
            <TableColumn fx:id="colNombre" prefWidth="106.66673278808594" text="Fecha" />
            <TableColumn fx:id="colDuracion" prefWidth="105.99990844726562" text="Hora" />
         <TableColumn prefWidth="291.333251953125" text="Resumen" />
        </columns>
    </TableView>
    <Button onAction="#onVolver" styleClass="cancel-button" text="↩️ Volver" />

</VBox>
