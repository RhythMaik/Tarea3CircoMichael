<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="panel-box" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.EspectaculoFormController">

    <Label fx:id="lblTitulo" styleClass="panel-title" text="🎪 Crear / Editar Espectáculo" />
    <Label styleClass="form-label" text="🏷Nombre" />
    <TextField fx:id="txtNombre" styleClass="form-field" />
    <Label styleClass="form-label" text="📅 Fecha de inicio" />
    <DatePicker fx:id="dpInicio" styleClass="form-field" />
    <Label styleClass="form-label" text="📅 Fecha de fin" />
    <DatePicker fx:id="dpFin" styleClass="form-field" />
    <Label fx:id="lblCoordinador" styleClass="form-label" text="👤 Coordinador" />
    <ComboBox fx:id="cbCoordinador" styleClass="form-field" />
    <HBox spacing="10">
        <Button onAction="#onGuardar" styleClass="action-button" text="💾 Guardar" />
        <Button onAction="#onCancelar" styleClass="cancel-button" text="↩️ Cancelar" />
    </HBox>

</VBox>
