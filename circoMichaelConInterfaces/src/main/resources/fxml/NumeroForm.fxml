<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="panel-box" stylesheets="@../styles/Styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.NumeroFormController">

    <Label fx:id="lblTitulo" styleClass="panel-title" text="🎬 Crear / Editar Número" />
    <Label styleClass="form-label" text="🔢 Orden" />
    <TextField fx:id="txtOrden" styleClass="form-field" />
    <Label styleClass="form-label" text="🏷 Nombre" />
    <TextField fx:id="txtNombre" styleClass="form-field" />
    <Label styleClass="form-label" text="⏱ Duración (minutos)" />
    <TextField fx:id="txtDuracion" styleClass="form-field" />
    <HBox spacing="10">
        <Button onAction="#onGuardar" styleClass="action-button" text="💾 Guardar" />
        <Button onAction="#onCancelar" styleClass="cancel-button" text="↩ Cancelar" />
    </HBox>

</VBox>
